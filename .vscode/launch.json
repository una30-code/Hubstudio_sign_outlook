{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: main.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Current File（跟随状态栏 Python 解释器）",
            "type": "debugpy",
            "request": "launch",
            // launch 和 attach 两种启动方式，launch 是启动一个新的 Python 解释器，attach 是附加到现有的 Python 解释器
            "program": "${file}",
            // 占位符变量，${file} 表示当前文件，${fileDirname} 表示当前文件的目录
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "python": "${command:python.interpreterPath}"
        }
    ]
}