# =============================================================================
# Phase-2（默认：browser/start 按环境 ID 启动，再用 debuggingPort 连 CDP）
# =============================================================================
# 与 phase-0 相同 connector 上的 HTTP API（用于 POST /api/v1/browser/start）
# HUBSTUDIO_API_BASE=http://127.0.0.1:6873
#
# 环境 ID = phase-0 创建返回的 containerCode；也可不设，改从 logs/archive/phase0_env_create_*.jsonl 最近成功记录读取
# HUBSTUDIO_CONTAINER=your_container_id_here

# Outlook 注册流程起始页（phase-2 必填）
OUTLOOK_REGISTER_URL=https://signup.live.com/signup

# 可选：与 phase-1 的 account 拼成邮箱，缺省 outlook.com
# OUTLOOK_EMAIL_DOMAIN=outlook.com

# phase-2 前请先运行 phase-1，以生成 logs/archive/phase1_user_profile_*.jsonl

# 可选：毫秒，缺省由代码默认 100000（整页导航）
# PAGE_LOAD_TIMEOUT_MS=100000

# 可选：已打开页后「每一步填表/点击」超时（毫秒），缺省 15000
# PHASE2_FORM_TIMEOUT_MS=15000

# 可选：各主步骤之间的额外间隔（毫秒），缺省 1000；0 表示关闭
# PHASE2_ACTION_DELAY_MS=1000

# 行为模拟（填表主步骤）：off | light | medium（或 1 | 2）；在 ACTION_DELAY 之后再随机等 [min,max] ms
# PHASE2_BEHAVIOR_SIMULATION=off
# PHASE2_BEHAVIOR_JITTER_MIN_MS=50
# PHASE2_BEHAVIOR_JITTER_MAX_MS=200

# 密码步 / 人机前建议 dismiss：尝试点掉「保存密码」条（DOM 可达时）；仍为 skip 则不处理（见 design.md §6.3）
# PHASE2_CHROME_PASSWORD_PROMPT=dismiss

# 填表成功后是否尝试人机（无障碍 + 长按）：未写本行时默认开启；若要关闭请显式 PHASE2_TRY_HOLD_CHALLENGE=0（见 design.md §6.5～§6.6）
# PHASE2_TRY_HOLD_CHALLENGE=0
# PHASE2_HOLD_AFTER_ACCESSIBLE_MS=2500
# PHASE2_HOLD_PRESS_DURATION_MS=4500

# 填表后人机页可能延迟出现：短睡（毫秒）+ 轮询上限（毫秒，不含短睡）；默认 4000 / 20000
# PHASE2_HOLD_PREP_SHORT_SLEEP_MS=4000
# PHASE2_HOLD_PREP_POLL_MS=20000

# 长按前是否重新解析人机卡片根节点（iframe 切换后建议保持开启；0/false 关闭）
# MS_HOLD_REFIND_ROOT_BEFORE_PRESS=1

# 进入人机子流程、关完密码条后：在顶层视口先轻点一次再点小人文（默认开）；0/false 关闭；点后等待毫秒可调
# PHASE2_HOLD_WARMUP_VIEWPORT_CLICK=1
# PHASE2_HOLD_WARMUP_SETTLE_MS=280

# 人机步：各候选 locator 等「可见」上限（毫秒）；点击仍用 PHASE2_FORM_TIMEOUT_MS；默认 2000
# PHASE2_HOLD_LOCATOR_PROBE_MS=2000

# scripts/ms_step*.py：CDP 附着后按 URL 子串选标签（默认 signup.live.com；留空=用浏览器第一个标签）
# PHASE2_PAGE_URL_CONTAINS=signup.live.com

# 直连 CDP 时可保留已打开页面（推荐做人机验证小闭环）；与 HUBSTUDIO_API_BASE+CONTAINER 二选一或配合
# HUBSTUDIO_CDP_URL=http://127.0.0.1:9222

# 分步 step02：无障碍按钮已消失仅见长按时「跳过点击」视为成功（1/true 开启，便于重复跑）
# MS_ACCESSIBILITY_NOOP_IF_NO_BUTTON=1

# 分步 step03：sleep | until_press；until_press 时 optional MS_STEP03_UNTIL_PRESS_TIMEOUT_MS=15000
# MS_STEP03_WAIT_MODE=sleep
# MS_STEP03_WAIT_MS=2500

# 可选：截图 / 日志目录（相对本仓库根目录；缺省分别为 screenshots、logs）
# SCREENSHOTS_DIR=screenshots
# LOG_DIR=logs

# =============================================================================
# Hubstudio HTTP API（phase-0 env/create；phase-2 默认 browser/start 同址）
# =============================================================================
# Hubstudio HTTP API 地址（先在 Hubstudio 客户端开启调试接口后查看）
HUBSTUDIO_API_BASE=http://127.0.0.1:6873

# 环境 ID / 容器 ID（从 Hubstudio 控制台查看，下方为占位示例）
HUBSTUDIO_CONTAINER=your_container_id_here

# Hubstudio 应用凭据（从 Hubstudio 控制台获取，切勿填入真实值）
HUBSTUDIO_APP_ID=your_app_id_here
HUBSTUDIO_GROUP_CODE=your_group_code_here
HUBSTUDIO_APP_SECRET=your_app_secret_here

# Hubstudio 客户端安装目录（本地绝对路径，不同机器会不同）
# HUBSTUDIO_DIR=D:\Hubstudio\x.x.x.x

# 调试开关
# HUBSTUDIO_DEBUG=1

# =============================================================================
# Phase-0（Hubstudio 环境创建）配置参考
# =============================================================================
# 方式一（推荐）：使用结构化 JSON 一次性传入
# HUBSTUDIO_ENV_CREATE_CONFIG_JSON={"site_name":"outlook","region":"美国","name_sequence_start":1,"proxy_raw":"1.2.3.4:1080:user:pass"}
#
# 方式二：使用扁平字段（与上方 JSON 二选一，或混合）
# SITE_NAME=outlook
# REGION=美国
# NAME_SEQUENCE_START=1
#
# 代理配置（二选一）
# PROXY_RAW=host:port:user:pass
# PROXY_HOST=1.2.3.4
# PROXY_PORT=1080
# PROXY_USERNAME=user
# PROXY_PASSWORD=pass
#
# 指纹 UA（可选）
# FINGERPRINT_UA=Mozilla/5.0 (...) Chrome/124.0.0.0 Safari/537.36
# FINGERPRINT_UA_VERSION=124.0.0.0

# =============================================================================
# Phase-1（用户信息生成）配置参考
# =============================================================================
# 运行开关（可选）
# PHASE=1  等价于  python src/main.py --phase1
#
# 随机种子：设置了则 phase-1 可完全复现同一人物；不设置（留空/注释）则每次运行人物不同
# USER_GEN_SEED=123
