# =============================================================================
# Phase-2（默认：browser/start 按环境 ID 启动，再用 debuggingPort 连 CDP）
# =============================================================================
# 与 phase-0 相同 connector 上的 HTTP API（用于 POST /api/v1/browser/start）
# HUBSTUDIO_API_BASE=http://127.0.0.1:6873
#
# 环境 ID = phase-0 创建返回的 containerCode；也可不设，改从 logs/archive/phase0_env_create_*.jsonl 最近成功记录读取
# HUBSTUDIO_CONTAINER=your_container_id_here

# Outlook 注册流程起始页（phase-2 必填）
OUTLOOK_REGISTER_URL=https://signup.live.com/signup

# 可选：与 phase-1 的 account 拼成邮箱，缺省 outlook.com
# OUTLOOK_EMAIL_DOMAIN=outlook.com

# phase-2 前请先运行 phase-1，以生成 logs/archive/phase1_user_profile_*.jsonl

# 可选：毫秒，缺省由代码默认 100000（整页导航）
# PAGE_LOAD_TIMEOUT_MS=100000

# 可选：已打开页后「每一步填表/点击」超时（毫秒），缺省 15000
# PHASE2_FORM_TIMEOUT_MS=15000

# 可选：各主步骤之间的额外间隔（毫秒），缺省 1000；0 表示关闭
# PHASE2_ACTION_DELAY_MS=1000

# 可选：密码步提交后是否尝试点 Chrome 密码条——缺省 skip（不处理）；需要时再设 save / dismiss（见 design.md §10.3）
# PHASE2_CHROME_PASSWORD_PROMPT=save

# 可选：截图 / 日志目录（相对本仓库根目录；缺省分别为 screenshots、logs）
# SCREENSHOTS_DIR=screenshots
# LOG_DIR=logs

# =============================================================================
# Hubstudio HTTP API（phase-0 env/create；phase-2 默认 browser/start 同址）
# =============================================================================
# Hubstudio HTTP API 地址（先在 Hubstudio 客户端开启调试接口后查看）
HUBSTUDIO_API_BASE=http://127.0.0.1:6873

# 环境 ID / 容器 ID（从 Hubstudio 控制台查看，下方为占位示例）
HUBSTUDIO_CONTAINER=your_container_id_here

# Hubstudio 应用凭据（从 Hubstudio 控制台获取，切勿填入真实值）
HUBSTUDIO_APP_ID=your_app_id_here
HUBSTUDIO_GROUP_CODE=your_group_code_here
HUBSTUDIO_APP_SECRET=your_app_secret_here

# Hubstudio 客户端安装目录（本地绝对路径，不同机器会不同）
# HUBSTUDIO_DIR=D:\Hubstudio\x.x.x.x

# 调试开关
# HUBSTUDIO_DEBUG=1

# =============================================================================
# Phase-0（Hubstudio 环境创建）配置参考
# =============================================================================
# 方式一（推荐）：使用结构化 JSON 一次性传入
# HUBSTUDIO_ENV_CREATE_CONFIG_JSON={"site_name":"outlook","region":"美国","name_sequence_start":1,"proxy_raw":"1.2.3.4:1080:user:pass"}
#
# 方式二：使用扁平字段（与上方 JSON 二选一，或混合）
# SITE_NAME=outlook
# REGION=美国
# NAME_SEQUENCE_START=1
#
# 代理配置（二选一）
# PROXY_RAW=host:port:user:pass
# PROXY_HOST=1.2.3.4
# PROXY_PORT=1080
# PROXY_USERNAME=user
# PROXY_PASSWORD=pass
#
# 指纹 UA（可选）
# FINGERPRINT_UA=Mozilla/5.0 (...) Chrome/124.0.0.0 Safari/537.36
# FINGERPRINT_UA_VERSION=124.0.0.0

# =============================================================================
# Phase-1（用户信息生成）配置参考
# =============================================================================
# 运行开关（可选）
# PHASE=1  等价于  python src/main.py --phase1
#
# 用于指定用户信息生成的随机种子（可选，便于测试或复现，留空则每次生成不同）
# USER_GEN_SEED=123
