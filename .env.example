# Hubstudio 调试端口 WebSocket（示例，请换成你的真实地址）
HUBSTUDIO_CDP_URL=ws://127.0.0.1:9222/devtools/browser/your-browser-id-here

# Outlook 注册流程起始页（示例 URL，请换成你要打开的地址）
OUTLOOK_REGISTER_URL=https://signup.live.com/signup

# 可选：毫秒，缺省由代码默认 30000
# PAGE_LOAD_TIMEOUT_MS=30000

# 可选：截图 / 日志目录（相对本仓库根目录；缺省分别为 screenshots、logs）
# SCREENSHOTS_DIR=screenshots
# LOG_DIR=logs

# =============================================================================
# Hubstudio HTTP API 参考变量（当前 Phase 1 不读取；留作后续阶段参考）
# =============================================================================
# Hubstudio HTTP API 地址（先在 Hubstudio 客户端开启调试接口后查看）
HUBSTUDIO_API_BASE=http://127.0.0.1:6873

# 环境 ID / 容器 ID（从 Hubstudio 控制台查看，下方为占位示例）
HUBSTUDIO_CONTAINER=your_container_id_here

# Hubstudio 应用凭据（从 Hubstudio 控制台获取，切勿填入真实值）
HUBSTUDIO_APP_ID=your_app_id_here
HUBSTUDIO_GROUP_CODE=your_group_code_here
HUBSTUDIO_APP_SECRET=your_app_secret_here

# Hubstudio 客户端安装目录（本地绝对路径，不同机器会不同）
# HUBSTUDIO_DIR=D:\Hubstudio\x.x.x.x

# 调试开关
# HUBSTUDIO_DEBUG=1

# =============================================================================
# Phase-0（Hubstudio 环境创建）配置参考
# =============================================================================
# 方式一（推荐）：使用结构化 JSON 一次性传入
# HUBSTUDIO_ENV_CREATE_CONFIG_JSON={"site_name":"outlook","region":"美国","name_sequence_start":1,"proxy_raw":"1.2.3.4:1080:user:pass"}
#
# 方式二：使用扁平字段（与上方 JSON 二选一，或混合）
# SITE_NAME=outlook
# REGION=美国
# NAME_SEQUENCE_START=1
#
# 代理配置（二选一）
# PROXY_RAW=host:port:user:pass
# PROXY_HOST=1.2.3.4
# PROXY_PORT=1080
# PROXY_USERNAME=user
# PROXY_PASSWORD=pass
#
# 指纹 UA（可选）
# FINGERPRINT_UA=Mozilla/5.0 (...) Chrome/124.0.0.0 Safari/537.36
# FINGERPRINT_UA_VERSION=124.0.0.0
