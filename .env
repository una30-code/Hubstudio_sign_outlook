# 本文件已被 .gitignore 忽略，可在此填写真实参数；勿将真实密钥写入 .env.example
#
# 以下三项必须从 Hubstudio 客户端/API 控制台复制，无法自动生成：
HUBSTUDIO_APP_ID=202507041390712519697494016
HUBSTUDIO_GROUP_CODE=12587204
HUBSTUDIO_APP_

# Hubstudio 安装目录（含 hubstudio_connector.exe），按本机实际路径修改
HUBSTUDIO_DIR=D:\Apps\Hubstudio

# HTTP API（与 outlook_automation/run_outlook_register.py 一致）
HUBSTUDIO_API_BASE=http://127.0.0.1:6873

# 环境 ID（与 outlook_automation 默认 HUBSTUDIO_CONTAINER 一致）
# HUBSTUDIO_CONTAINER=1507473418
 HUBSTUDIO_CONTAINER=1556758033

# 本仓库 load_settings 必填：启动环境后按调试端点替换端口与 browser GUID
# HUBSTUDIO_CDP_URL=ws://127.0.0.1:9222/devtools/browser/00000000-0000-0000-0000-000000000000

OUTLOOK_REGISTER_URL=https://signup.live.com/signup
SITE_NAME=outlook
REGION=美国
NAME_SEQUENCE_START=1
PROXY_RAW=168.158.101.69:12324:14a93ba47af82:e23bcf9abe

# 等价于  python src/main.py --phase1
PHASE=2
USER_GEN_SEED=123
# HUBSTUDIO_CONTAINER = 1507473418

# 可选：毫秒，缺省由代码默认 90000（整页导航）
PAGE_LOAD_TIMEOUT_MS=180000
# 可选：已打开页后「每一步填表/点击」超时（毫秒），缺省 12000；过大会导致邮箱/密码步骤体感卡顿
PHASE2_FORM_TIMEOUT_MS=3000


# 是否在 phase-2 执行“长按人机”挑战（0=关闭，缺省或1=开启）
# PHASE2_TRY_HOLD_CHALLENGE=0

# 密码条建议 dismiss：尝试点掉「保存密码」条（DOM 可达时）；
PHASE2_CHROME_PASSWORD_PROMPT=dismiss